# This is just an example
# The real file is called .env with . before env

# Copy this file to .env and fill in your values.
# .env is gitignored and must never be committed.

# Azure workspace credentials
SUBSCRIPTION_ID=your-subscription-id-here
RESOURCE_GROUP=your-resource-group-here
WORKSPACE_NAME=your-workspace-name-here

# Managed identity principal IDs (found in Azure portal under the compute cluster)
# Used by assign_identity and verify_identity scripts
COMPUTE_PRINCIPAL_ID=your-compute-principal-id-here
VERIFY_ASSIGNEE_ID=your-verify-assignee-id-here
