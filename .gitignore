# =============================================================================
# SECRETS & CREDENTIALS — never commit these
# =============================================================================
.env
*.pem
*.key

# Azure ML local config (created when you run az ml configure)
.azureml/

# =============================================================================
# PYTHON
# =============================================================================
__pycache__/
*.py[cod]
*.pyo
*.egg
*.egg-info/
dist/
build/
.eggs/

# Virtual environments
.venv/
venv/
env/

# =============================================================================
# DATA — never commit real datasets
# =============================================================================
data/raw/
data/processed/
*.csv
*.parquet
*.json
# Exception: keep config JSON files if you have any
!configs/*.json

# =============================================================================
# JUPYTER
# =============================================================================
.ipynb_checkpoints/
*.ipynb_checkpoints

# =============================================================================
# MODELS & ARTIFACTS — too large for git
# =============================================================================
*.pkl
*.joblib
*.pt
*.pth
outputs/
mlruns/
mlflow_artifacts/

# =============================================================================
# AZURE ML RUN OUTPUTS
# =============================================================================
azureml-logs/
azureml_artifacts/
user_logs/

# =============================================================================
# OS & EDITORS
# =============================================================================
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
