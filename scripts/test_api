#!/usr/bin/env bash
# Tests the deployed endpoint with a sample Iris data point.
# Requires ENDPOINT_URI and ENDPOINT_API_KEY to be set in your environment.
# Run test_endpoint.py first to obtain these values, then add them to your .env.

set -euo pipefail

# Load .env from repo root if variables are not already in the environment
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ENV_FILE="$SCRIPT_DIR/../.env"
if [ -f "$ENV_FILE" ]; then
  set -a && source "$ENV_FILE" && set +a
fi

: "${ENDPOINT_URI:?Need to set ENDPOINT_URI in .env (run test_endpoint.py first)}"
: "${ENDPOINT_API_KEY:?Need to set ENDPOINT_API_KEY in .env (run test_endpoint.py first)}"

curl --request POST "$ENDPOINT_URI" \
  --header "Authorization: Bearer $ENDPOINT_API_KEY" \
  --header "Content-Type: application/json" \
  --data '{"data": [[5.1, 3.5, 1.4, 0.2]]}'
